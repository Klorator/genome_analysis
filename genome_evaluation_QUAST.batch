#!/bin/bash -l

# SLURM setup
#SBATCH -A uppmax2026-1-61
#SBATCH -J quast_eval
#SBATCH --mail-type=ALL
#SBATCH -p pelle
#SBATCH -n 1
#SBATCH -t 00:20:00

set -euo pipefail

# Modules
module load QUAST/5.3.0-gfbf-2024a

# Script
cd "$HOME/genome_analysis"

ASSEMBLY_DIR="analysis/01_genomeAssembly"
OUTDIR="analysis/02_genomeEvaluation"
QUAST_OUTDIR="${OUTDIR}/quast"

mkdir -p "$OUTDIR" "$QUAST_OUTDIR"

ASSEMBLY_FASTA=$(find "$ASSEMBLY_DIR" -maxdepth 4 -type f -name "*.contigs.fasta" -printf '%T@ %p\n' | sort -nr | head -n 1 | cut -d' ' -f2-)

if [ -z "${ASSEMBLY_FASTA:-}" ] || [ ! -f "$ASSEMBLY_FASTA" ]; then
  echo "No Canu contig FASTA found in ${ASSEMBLY_DIR}" >&2
  exit 1
fi

RUN_PREFIX=$(basename "$(dirname "$ASSEMBLY_FASTA")")
OUTPUT_DIR="${QUAST_OUTDIR}/${RUN_PREFIX}"

echo "Selected assembly FASTA: ${ASSEMBLY_FASTA}"
echo "Evaluation run prefix: ${RUN_PREFIX}"
echo "Output directory: ${OUTPUT_DIR}"

quast_cmd=(
  quast.py "$ASSEMBLY_FASTA"
  --threads 1
  --output-dir "$OUTPUT_DIR"
  --k-mer-stats
)
echo "Running: ${quast_cmd[*]}"
"${quast_cmd[@]}"

tar_cmd=(tar -czf "${QUAST_OUTDIR}/${RUN_PREFIX}_quast_output.tar.gz" -C "$QUAST_OUTDIR" "$RUN_PREFIX")
echo "Running: ${tar_cmd[*]}"
"${tar_cmd[@]}"
